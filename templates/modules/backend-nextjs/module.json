{
  "name": "backend-nextjs",
  "kind": "runtime",
  "runtime": "node",
  "repeatable": true,
  "default_app_id": "next-api",
  "requires": [
    "core-monorepo"
  ],
  "conflicts": [],
  "emits": [
    {
      "source": "files/app",
      "target": "apps/__APP_ID__"
    }
  ],
  "check_metadata": {
    "runnable": true,
    "ux_capable": false,
    "needs_python": false,
    "needs_rust": false
  },
  "documentation": {
    "app_summary": "Next.js API backend service"
  }
}
