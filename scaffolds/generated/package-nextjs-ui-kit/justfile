set shell := ["bash", "-cu"]

install:
  mise install
  pnpm install

lint:
  pnpm --filter @workspace/ui-kit lint

typecheck:
  pnpm --filter @workspace/ui-kit typecheck

test:
  pnpm --filter @workspace/ui-kit test

ux:
  @echo "No UX-capable modules selected."

supply-chain:
  gitleaks dir . --config .gitleaks.toml
  osv-scanner scan source -r .
  pnpm audit --audit-level=high

ci: lint typecheck test ux supply-chain
